generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int            @id @default(autoincrement())
  name              String
  surname           String
  username          String         @unique
  email             String         @unique
  password          String
  role              UserRole       @default(USER)
  isVerified        Boolean        @default(false)
  verificationToken String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  profilePicture    String?
  newsComments      NewsComment[]
  newsLikes         NewsLikes[]
  notifications     Notification[]
  reports           Report[]

  assignedReports   Report[]       @relation("AssignedReports")
}

model Report {
  id             String         @id @default(uuid())
  userId         Int
  description    String
  country        String         @db.VarChar(50)
  city           String         @db.VarChar(100)
  address        String         @db.VarChar(255)
  date           DateTime       @default(now())
  state          ReportState    @default(PENDING)
  createAt       DateTime       @default(now())
  animal         String         @db.VarChar(50)
  title          String         @db.VarChar(30)
  analysisResult Json?
  analysisStatus String?        @default("pending")
  updatedAt      DateTime       @updatedAt
  evidences      Evidence[]
  notifications  Notification[]
  user           User           @relation(fields: [userId], references: [id])

  assignedToId     Int?          
  assignedTo       User?         @relation("AssignedReports", fields: [assignedToId], references: [id])
}

model Evidence {
  id        String   @id @default(uuid())
  reportId  String
  url       String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  report    Report   @relation(fields: [reportId], references: [id])
}

model Notification {
  id       Int      @id @default(autoincrement())
  userId   Int
  message  String
  createAt DateTime @default(now())
  reportId String?
  report   Report?  @relation(fields: [reportId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}

model News {
  id        String        @id @default(uuid())
  title     String
  context   String
  date_new  DateTime      @default(now())
  image_url String
  comments  NewsComment[]
  likes     NewsLikes[]
}

model NewsComment {
  id      String   @id @default(uuid())
  userId  Int
  newsId  String
  content String
  date    DateTime @default(now())
  news    News     @relation(fields: [newsId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
}

model NewsLikes {
  id     String   @id @default(uuid())
  userId Int
  newsId String
  date   DateTime @default(now())
  news   News     @relation(fields: [newsId], references: [id])
  user   User     @relation(fields: [userId], references: [id])

  @@unique([userId, newsId])
}

enum UserRole {
  USER
  ADMIN
}

enum ReportState {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
  ACCEPTED
}
